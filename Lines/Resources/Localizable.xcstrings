        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Score : %lld" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "スコア：%lld" } }
      }
    },
    "Next:" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Næste:" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Suivant :" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "次：" } }
      }
    },
    "Version %@" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Version %@" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Version %@" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "バージョン %@" } }
      }
    },
    "A classic Color Lines puzzle game." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Et klassisk Color Lines-puslespil." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Un jeu de puzzle Color Lines classique." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "クラシックなカラーラインズのパズルゲーム。" } }
      }
    },
    "This project is open source." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Dette projekt er open source." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ce projet est open source." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "このプロジェクトはオープンソースです。" } }
      }
    },
    "© 2026 Jens Lohmann" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "© 2026 Jens Lohmann" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "© 2026 Jens Lohmann" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "© 2026 Jens Lohmann" } }
      }
    },
    "Audio" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Lyd" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Audio" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "オーディオ" } }
      }
    },
    "Sound Effects" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Lydeffekter" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Effets sonores" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "効果音" } }
      }
    },
    "Goal" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Mål" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Objectif" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "目標" } }
      }
    },
    "Score as many points as possible by forming lines of 5 or more same-colored balls." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Scor så mange point som muligt ved at danne linjer af 5 eller flere kugler med samme farve." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Marquez le plus de points possible en formant des lignes de 5 billes ou plus de la même couleur." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "同じ色のボールを5個以上並べてラインを作り、できるだけ多くのポイントを獲得しましょう。" } }
      }
    },
    "Board" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Spillebræt" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Plateau" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ボード" } }
      }
    },
    "The game is played on a 9×9 grid. Each turn, 3 new balls of random colors appear." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Spillet foregår på et 9×9-gitter. Hver tur dukker 3 nye kugler i tilfældige farver op." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le jeu se joue sur une grille 9×9. À chaque tour, 3 nouvelles billes de couleurs aléatoires apparaissent." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "9×9のグリッド上でプレイします。毎ターン、ランダムな色のボールが3個出現します。" } }
      }
    },
    "Moving" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Flytning" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Déplacement" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "移動" } }
      }
    },
    "Tap a ball to select it, then tap an empty cell to move it there. The ball can only move if a clear path exists (no jumping over other balls)." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Tryk på en kugle for at vælge den, og tryk derefter på en tom celle for at flytte den derhen. Kuglen kan kun flyttes, hvis der er en fri vej (man kan ikke hoppe over andre kugler)." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Touchez une bille pour la sélectionner, puis touchez une case vide pour l'y déplacer. La bille ne peut se déplacer que s'il existe un chemin libre (pas de saut par-dessus d'autres billes)." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ボールをタップして選択し、空いているマスをタップして移動させます。ボールは障害物のない経路がある場合にのみ移動できます。" } }
      }
    },
    "Scoring" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Pointgivning" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Points" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "スコア" } }
      }
    },
    "When 5 or more balls of the same color form a horizontal, vertical, or diagonal line, they are removed and you earn points: 10 for 5 balls, plus 10 for each additional ball." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Når 5 eller flere kugler af samme farve danner en vandret, lodret eller diagonal linje, fjernes de, og du får point: 10 for 5 kugler plus 10 for hver ekstra kugle." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lorsque 5 billes ou plus de la même couleur forment une ligne horizontale, verticale ou diagonale, elles sont supprimées et vous gagnez des points : 10 pour 5 billes, plus 10 par bille supplémentaire." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "同じ色のボールが5個以上、横・縦・斜めに並ぶと消えてポイントが入ります。5個で10点、追加1個ごとに10点加算されます。" } }
      }
    },
    "Next Balls" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Næste kugler" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Prochaines billes" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "次のボール" } }
      }
    },
    "The 3 colors shown at the top tell you what colors will appear next. Plan your moves accordingly!" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "De 3 farver, der vises øverst, fortæller dig, hvilke farver der kommer næste gang. Planlæg dine træk derefter!" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les 3 couleurs affichées en haut indiquent les prochaines couleurs. Planifiez vos coups en conséquence !" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "画面上部に表示される3色が、次に出現するボールの色です。計画的に動かしましょう！" } }
      }
    },
    "The game ends when the board is completely full and no more balls can be placed." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Spillet slutter, når brættet er helt fyldt, og der ikke kan placeres flere kugler." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La partie se termine lorsque le plateau est complètement rempli et qu'aucune bille ne peut être placée." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ボードが完全に埋まり、ボールを置けなくなるとゲーム終了です。" } }
      }
    },
    "Tip" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Tip" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Astuce" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ヒント" } }
      }
    },
    "When you clear a line, the 3 new balls don't appear that turn — use this to chain moves strategically!" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Når du fjerner en linje, dukker de 3 nye kugler ikke op i den tur — brug det til at lave strategiske kædetræk!" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lorsque vous complétez une ligne, les 3 nouvelles billes n'apparaissent pas ce tour-là — utilisez cela pour enchaîner les coups stratégiquement !" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ラインを消すと、そのターンは新しいボールが出現しません。これを利用して戦略的に連鎖しましょう！" } }
      }
    }
  },
  "version" : "1.0"
}

