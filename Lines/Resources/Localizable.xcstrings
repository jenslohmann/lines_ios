        "ja" : { "stringUnit" : { "state" : "translated", "value" : "最終スコア：%lld" } }
      }
    },
    "🏆 New High Score!" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "🏆 Ny toprekord!" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "🏆 Nouveau record !" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "🏆 ハイスコア更新！" } }
      }
    },
    "No high scores yet." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Ingen topresultater endnu." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Aucun score pour le moment." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ハイスコアはまだありません。" } }
      }
    },
    "Score: %lld" : {
